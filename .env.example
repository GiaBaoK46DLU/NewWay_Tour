# ============================================================================
# NewWay Tourist — Environment variables template
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must never be committed.
# ============================================================================

# ---------- Supabase ----------
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------- Email Service (Resend) ----------
# Optional. If RESEND_API_KEY is empty, the app still works but booking
# confirmation / admin notification emails are skipped (logged as warnings).
#
# 1. Create a free API key at https://resend.com/api-keys
RESEND_API_KEY=
# 2. Sender address. For quick testing use Resend's sandbox sender (no domain
#    verification required):
#      EMAIL_FROM="NewWay Tourist <onboarding@resend.dev>"
#    In production use an address on a domain you verified in Resend.
EMAIL_FROM=
# 3. Address that receives "new booking" notifications (the tour owner/admin).
ADMIN_EMAIL=
